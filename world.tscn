[sub_resource type="GDScript" id="GDScript_036b0"]
script/source = "extends Label

func _ready() -> void:
	pass

func _process(_delta: float) -> void:
	text = \"HP: \" + str(Game.playerHP)
"

[sub_resource type="GDScript" id="GDScript_dwbse"]
script/source = "extends Label

func _ready() -> void:
	pass

func _process(_delta: float) -> void:
	text = \"Gold: \" + str(Game.Gold)
"

[sub_resource type="GDScript" id="GDScript_pkg7o"]
script/source = "extends Node2D

var Cherry = preload(\"res://Collectables/cherry.tscn\")
var Gem = preload(\"res://Collectables/gem.tscn\")

var rng = RandomNumberGenerator.new()

func _on_timer_timeout() -> void:
	var chance = rng.randf() 
	
	if chance < 0.2:
		return

	var item
	if chance > 0.8: 
		item = Gem.instantiate()
		item.position = Vector2(rng.randi_range(20, 1000), rng.randi_range(230, 250))
	else:
		item = Cherry.instantiate()
		item.position = Vector2(rng.randi_range(20, 1000), rng.randi_range(260, 290))

	add_child(item)
	
	$Timer.wait_time = rng.randf_range(0.5, 2.0)
"

